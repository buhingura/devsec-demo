# ============================================================
# .env.example — copy this to .env and fill in real values.
#
# NEVER commit .env to source control.
# .env is listed in .gitignore by default.
# ============================================================

# ------------------------------------------------------------
# REQUIRED
# ------------------------------------------------------------

# Generate a unique key for each environment:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
DJANGO_SECRET_KEY=change-me-to-a-long-random-string-at-least-50-chars

# ------------------------------------------------------------
# CORE BEHAVIOUR  (development defaults shown)
# ------------------------------------------------------------

# Set to "true" ONLY in development — never in staging or production.
DJANGO_DEBUG=true

# Comma-separated list of hostnames this server accepts.
# Production example: "myapp.com,www.myapp.com"
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Comma-separated trusted HTTPS origins for cross-origin unsafe requests
# (required when CSRF_COOKIE_SECURE=True).
# Production example: "https://myapp.com,https://www.myapp.com"
DJANGO_CSRF_TRUSTED_ORIGINS=

# ------------------------------------------------------------
# COOKIES & TRANSPORT  (keep "false" locally; set "true" in production)
# ------------------------------------------------------------

# Send cookies over HTTPS only.
DJANGO_COOKIE_SECURE=false

# Redirect all HTTP → HTTPS.
SECURE_SSL_REDIRECT=false

# Trust the X-Forwarded-Proto header from a reverse proxy.
# Enable ONLY when your proxy strips this header from untrusted clients.
DJANGO_TRUST_PROXY_SSL=false

# HSTS — start at 0 (off), raise to 31536000 (1 year) once HTTPS is stable.
# WARNING: once browsers cache an HSTS policy it cannot easily be reversed.
SECURE_HSTS_SECONDS=0
SECURE_HSTS_INCLUDE_SUBDOMAINS=false
SECURE_HSTS_PRELOAD=false

# ------------------------------------------------------------
# DATABASE  (SQLite is fine for development)
# ------------------------------------------------------------

# For PostgreSQL:
#   DJANGO_DB_ENGINE=django.db.backends.postgresql
#   DJANGO_DB_NAME=mydb
#   DJANGO_DB_USER=myuser
#   DJANGO_DB_PASSWORD=secret
#   DJANGO_DB_HOST=localhost
#   DJANGO_DB_PORT=5432

DJANGO_DB_ENGINE=django.db.backends.sqlite3
# DJANGO_DB_NAME defaults to BASE_DIR/db.sqlite3 when unset

# ------------------------------------------------------------
# EMAIL
# ------------------------------------------------------------

# Console backend logs emails to stdout — useful during development.
# Production alternatives:
#   django.core.mail.backends.smtp.EmailBackend
#   anymail.backends.sendgrid.EmailBackend
DJANGO_EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DEFAULT_FROM_EMAIL=noreply@localhost

# ------------------------------------------------------------
# BRUTE-FORCE PROTECTION
# ------------------------------------------------------------

LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCKOUT_SECONDS=900

# ------------------------------------------------------------
# PASSWORD RESET
# ------------------------------------------------------------

PASSWORD_RESET_TIMEOUT=3600

# ------------------------------------------------------------
# FILE UPLOADS
# ------------------------------------------------------------

AVATAR_MAX_UPLOAD_BYTES=2097152
DOCUMENT_MAX_UPLOAD_BYTES=5242880
